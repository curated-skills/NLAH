# Copy this file to `.env` and fill in the variables you actually need.
# LinguaClaw passes these straight to LiteLLM.
# Keep LiteLLM on the bundled local model-cost map by default to avoid a remote
# fetch on every fresh process start.
LITELLM_LOCAL_MODEL_COST_MAP=True
LINGUACLAW_API_KEY=
LINGUACLAW_API_BASE=
LINGUACLAW_MODEL=gpt-5.4-mini
LINGUACLAW_BASH_TIMEOUT_SECONDS=300
